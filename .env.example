# ── Harness Environment Variables ──────────────────────────────────
# Copy to .env and fill in production values.
# All have safe defaults for local development.

# ── XTDB Database ─────────────────────────────────────────────────
XTDB_USER=xtdb
XTDB_PASSWORD=xtdb
XTDB_EVENT_HOST=localhost
XTDB_EVENT_PORT=5433

# ── Garage S3 ─────────────────────────────────────────────────────
GARAGE_ACCESS_KEY=GK02e8e11dbf9b0325065707e5
GARAGE_SECRET_KEY=9834ce4f6ac15c899f31534198c3b15b67e0f30939a8911c7939c88e7603dc56
GARAGE_ADMIN_TOKEN=admin-secret
GARAGE_RPC_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Note: garage.toml and xtdb-primary/replica.yaml contain matching
# values that must be updated manually (no env var expansion support).

# ── Keycloak ──────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Service Ports ─────────────────────────────────────────────────
UI_PORT=3333
CHAT_PORT=3334
OPS_PORT=3335
# UI_PORT=3336 (harness-ui)
CI_PORT=3337
COLLECTOR_PORT=3338
# PORT=3339 (build-service)

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Infisical Secret Management ─────────────────────────────────
# Per-service Machine Identity credentials
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=prod

# Service-specific overrides (optional)
# HARNESS_UI_INFISICAL_CLIENT_ID=
# CI_RUNNER_INFISICAL_CLIENT_ID=
# BUILD_SERVICE_INFISICAL_CLIENT_ID=
