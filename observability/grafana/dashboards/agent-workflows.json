{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Agent Spawn Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(agent_spawn_duration_seconds_count{agent_exit_code=\"0\"}[1h])) / sum(rate(agent_spawn_duration_seconds_count[1h])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "green", "value": 90 }] } } }
    },
    {
      "title": "Agent Duration by Role (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_spawn_duration_seconds_bucket[5m])) by (le, agent_role))",
          "legendFormat": "{{agent_role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Workflow Step Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(workflow_step_duration_seconds_bucket[5m])) by (le, workflow_name))",
          "legendFormat": "{{workflow_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "XTDB Write Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(xtdb_insert_duration_seconds_bucket[5m])) by (le, xtdb_table))",
          "legendFormat": "{{xtdb_table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Workflow Completions vs Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(temporal_workflow_completed_total{workflow_type=~\"agentWorkflow|orchestrationWorkflow\"}[5m]))",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(temporal_workflow_failed_total{workflow_type=~\"agentWorkflow|orchestrationWorkflow\"}[5m]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "search",
          "serviceName": "harness-temporal-worker",
          "limit": 20,
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["harness", "agents", "workflows"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "Agents & Workflows — Harness",
  "uid": "harness-agents-workflows"
}
