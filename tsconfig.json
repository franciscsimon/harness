{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"]
  },
  "include": [
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "xtdb-event-logger/**/*.ts",
    "xtdb-event-logger-ui/**/*.ts",
    "xtdb-ops-api/**/*.ts",
    "xtdb-projector/**/*.ts",
    "harness-ui/**/*.ts",
    "web-chat/**/*.ts",
    "ci-runner/**/*.ts",
    "build-service/**/*.ts",
    "docker-event-collector/**/*.ts",
    "artifact-tracker/**/*.ts",
    "agent-spawner/**/*.ts",
    "code-quality/**/*.ts",
    "decision-log/**/*.ts",
    "deployment-tracker/**/*.ts",
    "history-retrieval/**/*.ts",
    "project-lifecycle/**/*.ts",
    "project-registry/**/*.ts",
    "quality-hooks/**/*.ts",
    "requirements-tracker/**/*.ts",
    "session-postmortem/**/*.ts",
    "session-status/**/*.ts",
    "sunk-cost-detector/**/*.ts",
    "workflow-engine/**/*.ts",
    "yak-shave/**/*.ts"
  ],
  "exclude": ["**/node_modules"]
}
