      "ev:payload": [
        {
          "@value": "{\"command\":\"# Check if there are any CLAUDE.md or agent config files in the project\\nfind ~/.pi -name \\\"CLAUDE.md\\\" -o -name \\\"agents.json\\\" -o -name \\\"agent.json\\\" 2>/dev/null\\necho \\\"---\\\"\\n# Check the patterns repo for anything about \\\"agents\\\" specifically\\ncurl -s https://api.github.com/repos/lexler/augmented-coding-patterns/git/trees/main?recursive=1 | python3 -c \\\"\\nimport sys, json\\ndata = json.load(sys.stdin)\\nfor item in data.get('tree', []):\\n    p = item['path']\\n    if 'agent' in p.lower() and not 'anti' in p:\\n        print(p)\\n\\\"\"}"
        }
      ],
