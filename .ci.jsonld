{
  "@context": {
    "schema": "https://schema.org/",
    "code": "https://pi.dev/code/"
  },
  "@type": "code:Pipeline",
  "schema:name": "harness CI",
  "code:steps": [
    {
      "@type": "code:PipelineStep",
      "schema:name": "lint",
      "code:image": "oven/bun:latest",
      "code:commands": ["bun install --frozen-lockfile", "npx biome ci ."]
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "typecheck",
      "code:image": "oven/bun:latest",
      "code:commands": ["bun install --frozen-lockfile", "npx tsc --noEmit"]
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "test",
      "code:image": "oven/bun:latest",
      "code:commands": ["bun install --frozen-lockfile", "bun test"]
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "security",
      "code:image": "zricethezav/gitleaks:latest",
      "code:commands": ["gitleaks detect --source=. --config=.gitleaks.toml --baseline-path=.gitleaks-baseline.json -v"],
      "code:blocking": true
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "audit",
      "code:image": "oven/bun:latest",
      "code:commands": ["npm audit --audit-level=high"]
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "contracts",
      "code:image": "oven/bun:latest",
      "code:commands": ["bun install --frozen-lockfile", "bun test test/contracts/schemas.ts"],
      "code:requiresServices": true
    },
    {
      "@type": "code:PipelineStep",
      "schema:name": "review-gate",
      "code:image": "oven/bun:latest",
      "code:commands": ["bun install --frozen-lockfile", "npx jiti review-gate/index.ts ."]
    }
  ]
}
