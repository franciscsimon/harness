+      },
+    ],
+  },
+
+  // ─── C# ─────────────────────────────────────────────────────────
+  {
+    language: "csharp",
+    extensions: [".cs"],
+    manifestFiles: ["*.csproj", "*.sln", "Directory.Build.props"],
