+        check: "clang-tidy src/*.cpp -- -std=c++17",
+        fix: "clang-tidy --fix src/*.cpp -- -std=c++17",
+        config: ".clang-tidy",
+        description: "C/C++ linter and static analyzer. Part of LLVM/Clang toolchain.",
+      },
+      {
